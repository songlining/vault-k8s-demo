# kind config template for the VSO cluster (kind-vso-lab / VSO_CONTEXT).
#
# Values wrapped in ${...} are substituted by scripts/create-clusters.sh from
# scripts/lib/two-cluster-env.sh via `sed` — do not hardcode ports here, edit
# scripts/lib/two-cluster-env.sh instead so every script stays in sync.
#
# networking.apiServerPort exposes this cluster's kube-apiserver on a stable
# host port so Vault (running in the Vault cluster) can reach it for
# Kubernetes auth TokenReview at https://${TWO_CLUSTER_HOST}:${VSO_API_HOST_PORT}.
# The certSANs patch adds ${TWO_CLUSTER_HOST} to the API server's serving
# certificate so that address validates over TLS.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: ${VSO_KIND_CLUSTER_NAME}
networking:
  apiServerAddress: "0.0.0.0"
  apiServerPort: ${VSO_API_HOST_PORT}
nodes:
  - role: control-plane
    kubeadmConfigPatches:
      - |
        kind: ClusterConfiguration
        apiServer:
          certSANs:
            - "${TWO_CLUSTER_HOST}"
            - "localhost"
            - "127.0.0.1"
