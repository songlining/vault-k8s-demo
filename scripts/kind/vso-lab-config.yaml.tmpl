# kind config template for the VSO cluster (kind-vso-lab / VSO_CONTEXT).
#
# Values wrapped in ${...} are substituted by scripts/create-clusters.sh from
# scripts/lib/two-cluster-env.sh via `sed` — do not hardcode ports here, edit
# scripts/lib/two-cluster-env.sh instead so every script stays in sync.
#
# networking.apiServerPort exposes this cluster's kube-apiserver on a stable
# host port so Vault (running in the Vault cluster) can retrieve OIDC discovery
# metadata and the advertised JWKS over TLS. The certSANs patch includes the
# external hostname in the API server's serving certificate.
#
# Kubernetes 1.36 uses kubeadm.k8s.io/v1beta4, where apiServer.extraArgs is a
# list of name/value pairs. These arguments make the ServiceAccount issuer
# self-consistent and externally reachable:
#
#   oidc_discovery_url == discovery issuer == JWT iss
#
# The discovery document advertises the same external API endpoint for JWKS.
# See docs/vso-oidc-discovery-handoff.md for the migration contract and the
# historical direct-JWKS documents for why the previous configuration differed.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: ${VSO_KIND_CLUSTER_NAME}
networking:
  apiServerAddress: "0.0.0.0"
  apiServerPort: ${VSO_API_HOST_PORT}
nodes:
  - role: control-plane
    kubeadmConfigPatches:
      - |
        apiVersion: kubeadm.k8s.io/v1beta4
        kind: ClusterConfiguration
        apiServer:
          certSANs:
            - "${TWO_CLUSTER_HOST}"
            - "localhost"
            - "127.0.0.1"
          extraArgs:
            - name: service-account-issuer
              value: "https://${TWO_CLUSTER_HOST}:${VSO_API_HOST_PORT}"
            - name: service-account-jwks-uri
              value: "https://${TWO_CLUSTER_HOST}:${VSO_API_HOST_PORT}/openid/v1/jwks"
