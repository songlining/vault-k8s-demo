# kind config template for the Vault cluster (kind-vault-lab / VAULT_CONTEXT).
#
# Values wrapped in ${...} are substituted by scripts/create-clusters.sh from
# scripts/lib/two-cluster-env.sh via `sed` — do not hardcode ports here, edit
# scripts/lib/two-cluster-env.sh instead so every script stays in sync.
#
# extraPortMappings exposes Vault's NodePort Service on a stable host port so
# pods in the VSO cluster can reach Vault at
# http://${TWO_CLUSTER_HOST}:${VAULT_HOST_PORT}.
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: ${VAULT_KIND_CLUSTER_NAME}
nodes:
  - role: control-plane
    extraPortMappings:
      - containerPort: ${VAULT_NODE_PORT}
        hostPort: ${VAULT_HOST_PORT}
        protocol: TCP
